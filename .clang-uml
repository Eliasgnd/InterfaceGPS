compilation_database_dir: .

diagrams:
  architecture:
    type: class
    glob:
      - "*.h"
      - "*.hpp"
    include:
      namespaces:
        - ""
    exclude:
      namespaces:
        - std
        - Ui
    using_namespace:
      - ""
    plantuml:
      before:
        - skinparam classAttributeIconSize 0
